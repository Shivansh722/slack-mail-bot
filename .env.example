PORT=3000
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-...
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Email Configuration (SMTP)
# Option 1: Gmail SMTP (easiest — requires App Password)
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use Gmail as SMTP_USER, app password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDER_EMAIL=your-email@gmail.com

# Option 2: Other SMTP (Mailgun, SendGrid SMTP, Postmark, etc.)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASS=your-smtp-password

# Firebase (optional — uses in-memory fallback if not set)
FIREBASE_SERVICE_ACCOUNT_JSON={
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/..."
}

# Development
MOCK_SEND=false
NODE_TLS_REJECT_UNAUTHORIZED=0
